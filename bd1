CREATE TABLE groups (
    group_id SERIAL PRIMARY KEY,
    group_name VARCHAR(100) NOT NULL
);

CREATE TABLE products (
    product_id SERIAL PRIMARY KEY,
    product_name VARCHAR(150) NOT NULL,
    group_id INTEGER REFERENCES groups(group_id),
    unit VARCHAR(20),
    price NUMERIC(10,2)
);

CREATE TABLE suppliers (
    supplier_id SERIAL PRIMARY KEY,
    supplier_name VARCHAR(150) NOT NULL,
    phone VARCHAR(30)
);

CREATE TABLE incoming_invoice (
    invoice_id SERIAL PRIMARY KEY,
    supplier_id INTEGER REFERENCES suppliers(supplier_id),
    invoice_date DATE NOT NULL,
    total_sum NUMERIC(10,2)
);

CREATE TABLE incoming_items (
    item_id SERIAL PRIMARY KEY,
    invoice_id INTEGER REFERENCES incoming_invoice(invoice_id),
    product_id INTEGER REFERENCES products(product_id),
    quantity INTEGER,
    price NUMERIC(10,2)
);

CREATE TABLE outgoing_invoice (
    out_invoice_id SERIAL PRIMARY KEY,
    invoice_date DATE NOT NULL
);

CREATE TABLE outgoing_items (
    out_item_id SERIAL PRIMARY KEY,
    out_invoice_id INTEGER REFERENCES outgoing_invoice(out_invoice_id),
    product_id INTEGER REFERENCES products(product_id),
    quantity INTEGER,
    price NUMERIC(10,2)
);

CREATE TABLE payments (
    payment_id SERIAL PRIMARY KEY,
    invoice_id INTEGER REFERENCES incoming_invoice(invoice_id),
    payment_date DATE,
    amount NUMERIC(10,2)
);
